# ─── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=paperprint
POSTGRES_USER=paperprint
POSTGRES_PASSWORD=change_me_in_production

# ─── Backend ────────────────────────────────────────────────────────────────
BACKEND_PORT=3001
NODE_ENV=development

# ─── JWT ────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Admin padrão (usado apenas no seed inicial) ────────────────────────────
SEED_ADMIN_LOGIN=admin
SEED_ADMIN_PASSWORD=Admin@1234

# ─── API Lyceum ─────────────────────────────────────────────────────────────
LYCEUM_BASE_URL=http://192.168.50.157:4000/api/v1

# ─── API Situator ────────────────────────────────────────────────────────────
# Se o hostname não resolver de dentro do Docker, use o IP diretamente:
# SITUATOR_BASE_URL=http://192.168.X.X/api/v1
SITUATOR_BASE_URL=http://network-services-middleware-situator.intranet.local/api/v1
SITUATOR_USER=situator_user
SITUATOR_PASSWORD=situator_password
# IP do servidor Situator para resolução DNS dentro do container Docker.
# Obtenha com: nslookup network-services-middleware-situator.intranet.local
SITUATOR_IP=
# Deixe SITUATOR_HOSTNAME sem alteração salvo se o hostname for diferente
SITUATOR_HOSTNAME=network-services-middleware-situator.intranet.local

# ─── API Vector AI ───────────────────────────────────────────────────────────
VECTOR_AI_BASE_URL=http://192.168.50.157:5000

# ─── Frontend (Vite build) ───────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
